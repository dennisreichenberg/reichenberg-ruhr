<section class="section" id="stack" data-id="#02 / technologien">
  <div class="container">
    <h2 class="section-title">Technologien</h2>
    <p class="section-subtitle">Mein Werkzeugkasten</p>

    <div class="stack-grid">
      <div class="stack-cat">
        <div class="stack-cat-header">
          <span class="stack-cat-title">Sprachen</span>
          <span class="stack-cat-num">04</span>
        </div>
        <div class="stack-items">
          <span class="chip">Delphi</span>
          <span class="chip">Python</span>
          <span class="chip">C#</span>
          <span class="chip">SQL</span>
        </div>
      </div>

      <div class="stack-cat">
        <div class="stack-cat-header">
          <span class="stack-cat-title">Frameworks &amp; Bibliotheken</span>
          <span class="stack-cat-num">05</span>
        </div>
        <div class="stack-items">
          <span class="chip">DevExpress</span>
          <span class="chip">UniDAC</span>
          <span class="chip">REST APIs</span>
          <span class="chip">Selenium</span>
          <span class="chip">BeautifulSoup</span>
        </div>
      </div>

      <div class="stack-cat">
        <div class="stack-cat-header">
          <span class="stack-cat-title">Datenbanken</span>
          <span class="stack-cat-num">03</span>
        </div>
        <div class="stack-items">
          <span class="chip">Oracle 19c</span>
          <span class="chip">SQLite</span>
          <span class="chip">Firebird</span>
        </div>
      </div>

      <div class="stack-cat">
        <div class="stack-cat-header">
          <span class="stack-cat-title">Tools &amp; Umgebung</span>
          <span class="stack-cat-num">05</span>
        </div>
        <div class="stack-items">
          <span class="chip">Git</span>
          <span class="chip">Docker</span>
          <span class="chip">Visual Studio</span>
          <span class="chip">PyCharm</span>
          <span class="chip">Windows</span>
        </div>
      </div>

      <div class="stack-cat">
        <div class="stack-cat-header">
          <span class="stack-cat-title">KI &amp; Infrastruktur · Schwerpunkt</span>
          <span class="stack-cat-num">04</span>
        </div>
        <div class="stack-items">
          <span class="chip">Ollama</span>
          <span class="chip">vLLM</span>
          <span class="chip">Open WebUI</span>
          <span class="chip">Selfhosted KI</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tech-categories {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .category-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }

  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tech-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .tech-item:hover {
    border-color: var(--color-accent);
  }

  .tech-item i {
    font-size: 1.25rem;
  }

  @media (max-width: 480px) {
    .tech-item {
      font-size: 0.8rem;
      padding: 0.4rem 0.75rem;
    }
  }
</style>
