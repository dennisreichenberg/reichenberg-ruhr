---
interface TechItem {
  name: string;
  icon?: string;
  category: 'language' | 'framework' | 'database' | 'tool' | 'ai';
}

const techItems: TechItem[] = [
  // Sprachen
  { name: 'Delphi', category: 'language' },
  { name: 'Python', icon: 'devicon-python-plain', category: 'language' },
  { name: 'C#', icon: 'devicon-csharp-plain', category: 'language' },
  { name: 'SQL', category: 'language' },

  // Frameworks & Bibliotheken
  { name: 'DevExpress', category: 'framework' },
  { name: 'UniDAC', category: 'framework' },
  { name: 'REST APIs', category: 'framework' },
  { name: 'Selenium', icon: 'devicon-selenium-original', category: 'framework' },
  { name: 'BeautifulSoup', category: 'framework' },

  // Datenbanken
  { name: 'Oracle 19c', icon: 'devicon-oracle-original', category: 'database' },
  { name: 'SQLite', icon: 'devicon-sqlite-plain', category: 'database' },
  { name: 'Firebird', category: 'database' },

  // Tools
  { name: 'Git', icon: 'devicon-git-plain', category: 'tool' },
  { name: 'Docker', icon: 'devicon-docker-plain', category: 'tool' },
  { name: 'Visual Studio', icon: 'devicon-visualstudio-plain', category: 'tool' },
  { name: 'PyCharm', icon: 'devicon-pycharm-plain', category: 'tool' },
  { name: 'Windows', icon: 'devicon-windows8-original', category: 'tool' },

  // KI & Selfhosted
  { name: 'Ollama', category: 'ai' },
  { name: 'vLLM', category: 'ai' },
  { name: 'Open WebUI', category: 'ai' },
  { name: 'Selfhosted KI', category: 'ai' },
];

const categories = [
  { key: 'language', label: 'Sprachen' },
  { key: 'framework', label: 'Frameworks & Bibliotheken' },
  { key: 'database', label: 'Datenbanken' },
  { key: 'tool', label: 'Tools & Umgebung' },
  { key: 'ai', label: 'KI & Infrastruktur' },
] as const;
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@v2.16.0/devicon.min.css" />

<section id="technologien">
  <div class="container">
    <h2 class="section-title">Technologien</h2>
    <p class="section-subtitle">Mein Werkzeugkasten</p>

    <div class="tech-categories">
      {categories.map(cat => {
        const items = techItems.filter(t => t.category === cat.key);
        if (items.length === 0) return null;
        return (
          <div class="tech-category">
            <h3 class="category-label">{cat.label}</h3>
            <div class="tech-grid">
              {items.map(item => (
                <div class="tech-item">
                  {item.icon && <i class={`${item.icon} colored`}></i>}
                  <span>{item.name}</span>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .tech-categories {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .category-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }

  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tech-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .tech-item:hover {
    border-color: var(--color-accent);
  }

  .tech-item i {
    font-size: 1.25rem;
  }

  @media (max-width: 480px) {
    .tech-item {
      font-size: 0.8rem;
      padding: 0.4rem 0.75rem;
    }
  }
</style>
