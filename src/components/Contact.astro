---
// Contact.astro — Simple contact section, no form to avoid spam/server-side logic
---

<section id="kontakt">
  <div class="container">
    <h2 class="section-title">Kontakt</h2>
    <p class="section-subtitle">Interesse an einer Zusammenarbeit?</p>

    <div class="contact-card">
      <p class="contact-intro">
        Sie haben ein Projekt, eine Frage oder möchten sich einfach vernetzen?
        Ich freue mich über Nachrichten.
      </p>

      <div class="contact-links">
        <a href="mailto:dennis@reichenberg.ruhr" class="contact-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          dennis@reichenberg.ruhr
        </a>

<a href="https://www.xing.com/profile/Dennis_Reichenberg4" target="_blank" rel="noopener" class="contact-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.188 0c-.517 0-.741.325-.927.66 0 0-7.455 13.224-7.702 13.657.015.024 4.919 9.023 4.919 9.023.17.308.436.66.967.66h3.454c.211 0 .375-.078.463-.22.089-.151.089-.346-.009-.536l-4.879-8.916c-.004-.006-.004-.016 0-.022L22.139.756c.095-.191.097-.387.006-.535C22.056.078 21.894 0 21.686 0h-3.498zM3.648 4.74c-.211 0-.385.074-.473.216-.09.149-.078.339.02.531l2.34 4.05c.004.01.004.016 0 .021L1.86 16.051c-.099.188-.093.381 0 .529.085.142.239.234.45.234h3.461c.518 0 .766-.348.945-.667l3.734-6.609-2.378-4.155c-.172-.315-.434-.643-.962-.643H3.648v.0z"/>
          </svg>
          XING Profil
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2.5rem;
    max-width: 540px;
  }

  .contact-intro {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text);
    font-size: 0.95rem;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
    background: var(--color-bg);
  }

  .contact-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateX(4px);
  }

  .contact-link svg {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .contact-card {
      padding: 1.5rem;
    }
  }
</style>
