<section class="section" id="contact" data-id="#04 / kontakt">
  <div class="container">
    <div class="contact-grid">
      <div>
        <span class="eyebrow" style="margin-bottom: 24px;">04 — Kontakt</span>
        <h2 class="contact-headline" style="margin-top: 18px;">Auf 'n <em>Kaffee</em> — oder ein Projekt?</h2>
        <p class="contact-sub">
          Ob Projekt, Frage oder einfach Vernetzen — schreib mir gern. Antwort meistens
          innerhalb 24 Stunden, höchstens 48, wenn der Strom mal weg is'.
        </p>
      </div>

      <div class="contact-list">
        <a href="mailto:dennis@reichenberg.ruhr" class="contact-item">
          <span class="contact-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
          </span>
          <div>
            <div class="contact-label">E-Mail</div>
            <div class="contact-value">dennis@reichenberg.ruhr</div>
          </div>
          <span class="contact-arrow">→</span>
        </a>

        <a href="https://www.xing.com/profile/Dennis_Reichenberg4" class="contact-item" target="_blank" rel="noopener">
          <span class="contact-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 6l5 6-7 9h4l5-6 5 6h4l-7-9 5-6h-4l-3 4-3-4z"/></svg>
          </span>
          <div>
            <div class="contact-label">Berufliches Netzwerk</div>
            <div class="contact-value">XING Profil</div>
          </div>
          <span class="contact-arrow">→</span>
        </a>

        <a href="https://github.com/dennisreichenberg" class="contact-item" target="_blank" rel="noopener">
          <span class="contact-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.71c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.04 1.53 1.04.9 1.53 2.35 1.09 2.92.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.6 1.03 2.69 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2z"/></svg>
          </span>
          <div>
            <div class="contact-label">Code &amp; Open Source</div>
            <div class="contact-value">GitHub Profil</div>
          </div>
          <span class="contact-arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2.5rem;
    max-width: 540px;
  }

  .contact-intro {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text);
    font-size: 0.95rem;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
    background: var(--color-bg);
  }

  .contact-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .contact-link svg {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .contact-card {
      padding: 1.5rem;
    }
  }
</style>
