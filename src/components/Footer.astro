---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-copy">
      &copy; {year} Dennis Reichenberg · Ruhrgebiet, NRW
    </p>
    <p class="footer-links">
      <a href="mailto:dennis@reichenberg.ruhr">dennis@reichenberg.ruhr</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 2rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-copy,
  .footer-links {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
