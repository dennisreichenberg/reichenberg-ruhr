<style>
  .all-tools-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    border: 1px solid var(--border);
    padding: 10px 18px;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .all-tools-link::before {
    content: "$ ";
    color: var(--muted);
  }
  .all-tools-link:hover {
    border-color: var(--accent);
    background: var(--surface-2);
  }
  .all-tools-link .arrow {
    transition: transform 0.15s ease;
  }
  .all-tools-link:hover .arrow {
    transform: translateX(3px);
  }
  .flagship {
    border-color: var(--accent);
  }
</style>
