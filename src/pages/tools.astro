---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Tools – Dennis Reichenberg';
const description = 'Open-Source CLI-Tools fuer lokale KI-Infrastruktur: devlog, vllm-monitor, model-manager. Alle Tools sind auf PyPI veroeffentlicht und lokal installierbar.';
const url = 'https://reichenberg.ruhr/tools';

const tools = [
  {
    name: 'devlog',
    tagline: 'Arbeitslog mit KI-Zusammenfassungen',
    description: 'Taeglich in Sekunden den Arbeitsfortschritt festhalten. Ein lokales LLM schreibt daraus woechentliche Zusammenfassungen, Standup-Updates und PR-Beschreibungen – ohne Cloud, ohne API-Key.',
    install: 'pip install devlog',
    githubUrl: 'https://github.com/dennisreichenberg/devlog',
    tags: ['Python', 'Ollama', 'Local LLM', 'CLI', 'Produktivitaet'],
  },
  {
    name: 'vllm-monitor',
    tagline: 'Echtzeit-Dashboard fuer vLLM-Server',
    description: 'Terminal-Dashboard zur Live-Ueberwachung von vLLM-Servermetriken: GPU-Auslastung, Durchsatz, Latenz und Warteschlangen auf einen Blick – direkt im Terminal.',
    install: 'pip install vllm-monitor',
    githubUrl: 'https://github.com/dennisreichenberg/vllm-monitor',
    tags: ['Python', 'vLLM', 'TUI', 'Monitoring', 'CLI'],
  },
  {
    name: 'model-manager',
    tagline: 'Ollama-Modelle verwalten',
    description: 'Einheitliche Kommandozeilen-Verwaltung fuer Ollama-Modelle: Auflisten, Herunterladen, Entfernen und Taggen – alles in einem Tool ohne Umwege ueber die Ollama-API direkt.',
    install: 'pip install model-manager',
    githubUrl: 'https://github.com/dennisreichenberg/model-manager',
    tags: ['Python', 'Ollama', 'CLI', 'Local LLM'],
  },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Dennis Reichenberg" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={url} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>

  <body>
    <Nav />
    <main>
      <section id="tools">
        <div class="container">
          <a href="/" class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            Zurueck zur Startseite
          </a>

          <h1 class="section-title">Tools</h1>
          <p class="section-subtitle">Open-Source CLI-Tools fuer lokale KI-Infrastruktur</p>
          <p class="intro">
            Diese Tools entstanden aus dem Alltag mit selbst gehosteten KI-Systemen. Alle sind auf
            <a href="https://pypi.org" target="_blank" rel="noopener">PyPI</a> veroeffentlicht,
            lokal installierbar und benoetigen keinen Cloud-Zugang.
          </p>

          <div class="tools-grid">
            {tools.map((tool) => (
              <article class="tool-card">
                <div class="tool-header">
                  <div>
                    <h2 class="tool-name">{tool.name}</h2>
                    <p class="tool-tagline">{tool.tagline}</p>
                  </div>
                  <a href={tool.githubUrl} target="_blank" rel="noopener" class="github-link" aria-label={`${tool.name} auf GitHub`}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                </div>

                <p class="tool-description">{tool.description}</p>

                <div class="install-block">
                  <span class="install-label">Installation</span>
                  <code class="install-cmd">{tool.install}</code>
                </div>

                <div class="tool-tags">
                  {tool.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .section-title {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 3rem;
    height: 3px;
    background: var(--color-accent);
    margin-top: 0.5rem;
    border-radius: 2px;
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-top: 1rem;
    margin-bottom: 1.25rem;
  }

  .intro {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.75;
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .tools-grid {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .tool-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .tool-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .tool-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .tool-name {
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .tool-tagline {
    font-size: 0.95rem;
    color: #f1f5f9;
    font-weight: 500;
  }

  .github-link {
    color: var(--color-text-muted);
    transition: color 0.2s ease;
    flex-shrink: 0;
    padding-top: 0.125rem;
  }

  .github-link:hover {
    color: #f1f5f9;
  }

  .tool-description {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.75;
  }

  .install-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
  }

  .install-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .install-cmd {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9rem;
    color: #a5f3fc;
  }

  .tool-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    border-radius: 0.375rem;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.25);
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .tool-card {
      padding: 1.25rem;
    }

    .install-block {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.375rem;
    }
  }
</style>
