---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Tools – Dennis Reichenberg';
const description = 'Open-Source CLI-Tools fuer lokale KI-Infrastruktur: Ollama, vLLM, Agent-Frameworks. Alle Tools auf GitHub, viele auf PyPI installierbar.';
const url = 'https://reichenberg.ruhr/tools';

interface Tool {
  name: string;
  tagline: string;
  description: string;
  install: string | null;
  githubUrl: string;
  pypiUrl: string | null;
  tags: string[];
}

interface Category {
  label: string;
  id: string;
  tools: Tool[];
}

const categories: Category[] = [
  {
    label: 'Ollama Tools',
    id: 'ollama',
    tools: [
      {
        name: 'ollama-commit',
        tagline: 'AI-generierte Git-Commit-Messages',
        description: 'Generiert automatisch aussagekraeftige Git-Commit-Nachrichten mit lokalen LLMs ueber Ollama. Analysiert den Diff und schlaegt eine passende Nachricht vor.',
        install: 'pip install ollama-commit',
        githubUrl: 'https://github.com/dennisreichenberg/ollama-commit',
        pypiUrl: 'https://pypi.org/project/ollama-commit/',
        tags: ['Python', 'Ollama', 'Git', 'CLI', 'Produktivitaet'],
      },
      {
        name: 'ollama-tui',
        tagline: 'Terminal-UI fuer Ollama-Chats',
        description: 'Keyboard-getriebene Terminal-UI fuer Chats mit lokalen Ollama-Modellen. Schnelle Modellwahl, Konversationen und Streaming direkt im Terminal.',
        install: null,
        githubUrl: 'https://github.com/dennisreichenberg/ollama-tui',
        pypiUrl: null,
        tags: ['Python', 'Ollama', 'TUI', 'Chat', 'CLI'],
      },
      {
        name: 'devlog',
        tagline: 'Arbeitslog mit KI-Zusammenfassungen',
        description: 'Taeglich in Sekunden den Arbeitsfortschritt festhalten. Ein lokales LLM schreibt daraus woechentliche Zusammenfassungen, Standup-Updates und PR-Beschreibungen.',
        install: 'pip install devlog',
        githubUrl: 'https://github.com/dennisreichenberg/devlog',
        pypiUrl: 'https://pypi.org/project/devlog/',
        tags: ['Python', 'Ollama', 'Local LLM', 'CLI', 'Produktivitaet'],
      },
      {
        name: 'llm-bench',
        tagline: 'CLI-Benchmark-Suite fuer lokale LLMs',
        description: 'Benchmarkt lokale LLM-Modelle mit konfigurierbaren Prompts und misst Antwortzeit, Token-Rate und Qualitaet.',
        install: 'pip install llm-bench',
        githubUrl: 'https://github.com/dennisreichenberg/llm-bench',
        pypiUrl: 'https://pypi.org/project/llm-bench/',
        tags: ['Python', 'Ollama', 'Benchmark', 'CLI'],
      },
      {
        name: 'llm-shell',
        tagline: 'Shell-Befehle aus Klartext',
        description: 'AI-gestuetzter Shell-Command-Vorschlag: Beschreibe in Klartext, was du tun willst, und erhalte den passenden Shell-Befehl von einem lokalen LLM.',
        install: 'pip install llm-shell',
        githubUrl: 'https://github.com/dennisreichenberg/llm-shell',
        pypiUrl: 'https://pypi.org/project/llm-shell/',
        tags: ['Python', 'Ollama', 'Shell', 'CLI', 'Produktivitaet'],
      },
      {
        name: 'local-rag',
        tagline: 'Private Dokumenten-Q&A',
        description: 'Lokales Retrieval-Augmented-Generation-System: Dokumente indexieren und mit lokalen LLMs befragen. Laeuft komplett lokal, keine Daten verlassen den Rechner.',
        install: 'pip install ollama-local-rag',
        githubUrl: 'https://github.com/dennisreichenberg/local-rag',
        pypiUrl: 'https://pypi.org/project/ollama-local-rag/',
        tags: ['Python', 'Ollama', 'RAG', 'CLI', 'Datenschutz'],
      },
      {
        name: 'model-manager',
        tagline: 'Ollama-Modelle verwalten',
        description: 'Einheitliche Kommandozeilen-Verwaltung fuer Ollama-Modelle: Auflisten, Herunterladen, Entfernen und Taggen in einem Tool.',
        install: 'pip install model-manager',
        githubUrl: 'https://github.com/dennisreichenberg/model-manager',
        pypiUrl: 'https://pypi.org/project/model-manager/',
        tags: ['Python', 'Ollama', 'CLI', 'Local LLM'],
      },
      {
        name: 'prompt-lab',
        tagline: 'Side-by-side Prompt-Tests',
        description: 'Prompts parallel ueber mehrere lokale Ollama-Modelle testen und Ergebnisse direkt vergleichen. Ideal fuer Prompt-Engineering und Modellauswahl.',
        install: null,
        githubUrl: 'https://github.com/dennisreichenberg/prompt-lab',
        pypiUrl: null,
        tags: ['Python', 'Ollama', 'Prompt Engineering', 'CLI'],
      },
    ],
  },
  {
    label: 'vLLM Tools',
    id: 'vllm',
    tools: [
      {
        name: 'vllm-bench',
        tagline: 'vLLM-Server-Benchmark',
        description: 'CLI-Benchmark fuer vLLM-Server-Performance: TTFT, Throughput und Inter-Token-Latenz messen und vergleichen.',
        install: null,
        githubUrl: 'https://github.com/dennisreichenberg/vllm-bench',
        pypiUrl: null,
        tags: ['Python', 'vLLM', 'Benchmark', 'CLI', 'Performance'],
      },
      {
        name: 'vllm-config',
        tagline: 'Hardware-bewusste vLLM-Konfiguration',
        description: 'Optimiert vLLM-Startkonfigurationen basierend auf der vorhandenen Hardware. Erkennt GPU-Speicher, CPU-Kerne und schlaegt passende Parameter vor.',
        install: null,
        githubUrl: 'https://github.com/dennisreichenberg/vllm-config',
        pypiUrl: null,
        tags: ['Python', 'vLLM', 'CLI', 'GPU', 'Konfiguration'],
      },
      {
        name: 'vllm-monitor',
        tagline: 'Echtzeit-Dashboard fuer vLLM',
        description: 'Terminal-Dashboard zur Live-Ueberwachung von vLLM-Servermetriken: GPU-Auslastung, Durchsatz, Latenz und Warteschlangen auf einen Blick.',
        install: null,
        githubUrl: 'https://github.com/dennisreichenberg/vllm-monitor',
        pypiUrl: null,
        tags: ['Python', 'vLLM', 'TUI', 'Monitoring', 'CLI'],
      },
    ],
  },
  {
    label: 'AI Infrastructure',
    id: 'infra',
    tools: [
      {
        name: 'ollama-proxy',
        tagline: 'Unified API-Router',
        description: 'OpenAI-kompatibler API-Router, der Anfragen an Ollama- und vLLM-Backends verteilt. Ein Endpunkt fuer alle lokalen Modelle.',
        install: 'pip install ollama-proxy',
        githubUrl: 'https://github.com/dennisreichenberg/ollama-proxy',
        pypiUrl: 'https://pypi.org/project/ollama-proxy/',
        tags: ['Python', 'Ollama', 'vLLM', 'API', 'Infrastructure'],
      },
      {
        name: 'agent-runner',
        tagline: 'Agent-Loop-Framework',
        description: 'CLI-Agent-Loop-Framework mit Tool-Use fuer lokale LLMs. Definiere Tools, starte Agenten und lass sie autonom Aufgaben loesen.',
        install: 'pip install agent-runner',
        githubUrl: 'https://github.com/dennisreichenberg/agent-runner',
        pypiUrl: 'https://pypi.org/project/agent-runner/',
        tags: ['Python', 'Agents', 'Tool-Use', 'CLI', 'Local LLM'],
      },
      {
        name: 'model-eval',
        tagline: 'LLM-Qualitaet bewerten',
        description: 'Lokale LLM-Qualitaet bewerten mit exact-match, fuzzy-Vergleich und LLM-as-Judge. Ideal fuer Modellauswahl und Regressionstests.',
        install: null,
        githubUrl: 'https://github.com/dennisreichenberg/model-eval',
        pypiUrl: null,
        tags: ['Python', 'Evaluation', 'Benchmark', 'CLI', 'Local LLM'],
      },
    ],
  },
  {
    label: 'Self-Hosted Stack',
    id: 'stack',
    tools: [
      {
        name: 'langfuse',
        tagline: 'Self-hosted LLM-Observability',
        description: 'Traces, Evals, Prompt-Management und Cost-Tracking fuer alle lokalen LLM-Tools. UI auf Port 3030. Configs, Secrets-Template und Integrations-Hinweise im Repo.',
        install: 'docker compose up -d',
        githubUrl: 'https://github.com/dennisreichenberg/reichenberg-ruhr/tree/main/langfuse',
        pypiUrl: null,
        tags: ['Docker', 'Observability', 'Self-Hosted', 'LLM-Ops', 'Langfuse'],
      },
      {
        name: 'litellm-proxy',
        tagline: 'OpenAI-kompatibler Unified-Gateway',
        description: 'API-Gateway fuer Ollama und vLLM, optional mit Langfuse-Callback. Ein OpenAI-kompatibler Endpunkt fuer alle lokalen Backends. Proxy auf Port 4000.',
        install: 'docker compose up -d',
        githubUrl: 'https://github.com/dennisreichenberg/reichenberg-ruhr/tree/main/litellm-proxy',
        pypiUrl: null,
        tags: ['Docker', 'API Gateway', 'Self-Hosted', 'LiteLLM', 'Ollama', 'vLLM'],
      },
    ],
  },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Dennis Reichenberg" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={url} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <Nav />
    <main>
      <section id="tools">
        <div class="container">
          <a href="/" class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            Zurueck zur Startseite
          </a>

          <h1 class="section-title">Tools</h1>
          <p class="section-subtitle">14 CLI-Tools + 2 Self-Hosted Stacks fuer lokale KI-Infrastruktur</p>
          <p class="intro">
            Diese Tools entstanden aus dem Alltag mit selbst gehosteten KI-Systemen.
            Alle sind auf <a href="https://github.com/dennisreichenberg" target="_blank" rel="noopener">GitHub</a> verfuegbar.
            Tools mit PyPI-Badge sind sofort per <code>pip install</code> installierbar.
          </p>

          {categories.map((cat) => (
            <div class="tool-category" id={cat.id}>
              <div class="cat-header">
                <span class="cat-label">{cat.label}</span>
                <span class="cat-count">{cat.tools.length} Tools</span>
              </div>

              <div class="tools-grid">
                {cat.tools.map((tool) => (
                  <article class="tool-card">
                    <div class="tool-header">
                      <div>
                        <h2 class="tool-name">{tool.name}</h2>
                        <p class="tool-tagline">{tool.tagline}</p>
                      </div>
                      <div class="tool-badges">
                        {tool.pypiUrl ? (
                          <a href={tool.pypiUrl} target="_blank" rel="noopener" class="badge badge-pypi">PyPI</a>
                        ) : tool.install?.startsWith('docker') ? (
                          <span class="badge badge-docker">Docker</span>
                        ) : (
                          <span class="badge badge-soon">Coming soon</span>
                        )}
                        <a href={tool.githubUrl} target="_blank" rel="noopener" class="badge">GitHub</a>
                      </div>
                    </div>

                    <p class="tool-description">{tool.description}</p>

                    {tool.install ? (
                      <div class="install-block">
                        <span class="install-label">Installation</span>
                        <code class="install-cmd">{tool.install}</code>
                      </div>
                    ) : (
                      <div class="install-block install-pending">
                        <span class="install-label">Status</span>
                        <span class="install-note">PyPI-Veroeffentlichung in Kuerze</span>
                      </div>
                    )}

                    <div class="tool-tags">
                      {tool.tags.map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  </article>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--muted);
    margin-bottom: 2.5rem;
    transition: color 0.2s ease;
    font-family: var(--font-mono);
  }

  .back-link:hover {
    color: var(--ink);
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
    font-family: var(--font-mono);
  }
  .section-title::before {
    content: "## ";
    color: var(--accent);
    font-weight: 400;
  }

  .section-subtitle {
    color: var(--muted);
    font-size: 1.05rem;
    margin-top: 1rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
  }

  .intro {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.75;
    max-width: 600px;
    margin-bottom: 3rem;
    font-family: var(--font-mono);
  }

  .intro a {
    color: var(--accent);
    border-bottom: 1px solid color-mix(in oklch, var(--accent) 50%, transparent);
  }

  .intro a:hover {
    color: var(--ink);
    border-color: var(--ink);
  }

  .intro code {
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .tool-category {
    margin-bottom: 3.5rem;
  }

  .tool-category:last-child {
    margin-bottom: 0;
  }

  .cat-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 1.5rem;
    padding-bottom: 10px;
    border-bottom: 1px dashed var(--border);
    font-family: var(--font-mono);
  }

  .cat-label {
    font-size: 13px;
    color: var(--accent);
    font-weight: 500;
  }

  .cat-label::before {
    content: "// ";
    color: var(--muted);
  }

  .cat-count {
    color: var(--muted);
    font-size: 11px;
    margin-left: auto;
  }

  .tools-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .tool-card {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 0;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s ease;
  }

  .tool-card:hover {
    border-color: var(--accent);
  }

  .tool-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .tool-badges {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .tool-name {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.2rem;
  }

  .tool-name::before {
    content: "$ ";
    color: var(--muted);
    font-weight: 400;
  }

  .tool-tagline {
    font-size: 0.85rem;
    color: var(--ink);
    font-weight: 500;
    font-family: var(--font-mono);
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 0;
    letter-spacing: 0.04em;
    border: 1px solid var(--border);
    color: var(--muted);
    transition: all 0.15s;
    white-space: nowrap;
  }

  .badge:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .badge-pypi {
    background: var(--accent);
    color: var(--bg);
    border-color: transparent;
  }

  .badge-pypi:hover {
    background: var(--ink);
    color: var(--bg);
  }

  .badge-docker {
    background: #0db7ed;
    color: #fff;
    border-color: transparent;
  }

  .badge-soon {
    border-style: dashed;
    color: var(--muted);
    font-style: italic;
  }

  .tool-description {
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1.7;
    font-family: var(--font-mono);
  }

  .install-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0;
    padding: 0.625rem 0.875rem;
  }

  .install-pending {
    border-style: dashed;
  }

  .install-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    font-family: var(--font-mono);
  }

  .install-cmd {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink);
  }

  .install-cmd::before {
    content: '$ ';
    color: var(--accent);
  }

  .install-note {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    font-style: italic;
  }

  .tool-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.2rem 0.5rem;
    border-radius: 0;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: var(--font-mono);
  }

  #tools {
    padding: var(--gap) 0;
  }

  @media (max-width: 640px) {
    .tool-card {
      padding: 1.25rem;
    }

    .tool-header {
      flex-direction: column;
      gap: 0.75rem;
    }

    .install-block {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.375rem;
    }
  }
</style>
