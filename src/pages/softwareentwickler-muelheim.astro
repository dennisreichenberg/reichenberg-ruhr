---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Softwareentwickler Mülheim an der Ruhr - Dennis Reichenberg | Freelance Developer';
const description = 'Dennis Reichenberg - erfahrener Softwareentwickler aus Mülheim an der Ruhr. Freelance Web- und Backend-Entwicklung, API-Integration und IT-Beratung für Unternehmen im Ruhrgebiet und NRW. Jetzt Kontakt aufnehmen.';
const url = 'https://reichenberg.ruhr/softwareentwickler-muelheim';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Dennis Reichenberg" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={url} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "@id": "https://reichenberg.ruhr/#dennis",
            "name": "Dennis Reichenberg",
            "jobTitle": "Softwareentwickler",
            "description": "Freiberuflicher Softwareentwickler aus Mülheim an der Ruhr, spezialisiert auf Webentwicklung, APIs und moderne JavaScript-Frameworks.",
            "url": "https://reichenberg.ruhr",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Mülheim an der Ruhr",
              "addressRegion": "Nordrhein-Westfalen",
              "addressCountry": "DE"
            },
            "knowsAbout": ["Webentwicklung", "React", "Node.js", "TypeScript", "Python", "AWS", "PostgreSQL", "Softwarearchitektur"]
          },
          {
            "@type": "ProfessionalService",
            "@id": "https://reichenberg.ruhr/softwareentwickler-muelheim#service",
            "name": "Softwareentwicklung Mülheim an der Ruhr – Dennis Reichenberg",
            "description": "Freiberufliche Softwareentwicklung, Webentwicklung und IT-Beratung aus Mülheim an der Ruhr für das Ruhrgebiet und NRW.",
            "provider": {
              "@id": "https://reichenberg.ruhr/#dennis"
            },
            "areaServed": [
              {
                "@type": "City",
                "name": "Mülheim an der Ruhr",
                "sameAs": "https://www.wikidata.org/wiki/Q11943"
              },
              {
                "@type": "State",
                "name": "Nordrhein-Westfalen",
                "sameAs": "https://www.wikidata.org/wiki/Q1198"
              }
            ],
            "serviceType": "Softwareentwicklung",
            "url": "https://reichenberg.ruhr/softwareentwickler-muelheim",
            "offers": {
              "@type": "Offer",
              "name": "Freelance Softwareentwicklung",
              "description": "Web- und Backend-Entwicklung, API-Integration und technische Beratung für Unternehmen im Ruhrgebiet und NRW"
            }
          },
          {
            "@type": "FAQPage",
            "@id": "https://reichenberg.ruhr/softwareentwickler-muelheim#faq",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "Arbeiten Sie auch remote oder nur in Mülheim an der Ruhr?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Ich arbeite primär remote und bin deshalb örtlich flexibel einsetzbar. Für Kick-off-Meetings, Workshops oder regelmäßige Abstimmungen stehe ich im Raum Mülheim an der Ruhr, dem Ruhrgebiet und ganz NRW gerne persönlich zur Verfügung."
                }
              },
              {
                "@type": "Question",
                "name": "Für welche Unternehmensgrößen sind Sie der richtige Ansprechpartner?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Ich unterstütze sowohl Einzelunternehmer und Startups als auch mittelständische Unternehmen. Entscheidend ist ein klar definiertes Projektziel und die Bereitschaft zur agilen, ergebnisorientierten Zusammenarbeit."
                }
              },
              {
                "@type": "Question",
                "name": "Welche Projekte nehmen Sie an?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Webentwicklung, mobile Web-Apps, Backend-APIs, Drittanbieter-Integrationen, technische Beratung, Code-Reviews sowie Architekturplanung. Auch temporäre Verstärkung für bestehende Entwicklungsteams ist möglich."
                }
              }
            ]
          }
        ]
      }
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body>
    <Nav />
    <main>
      <!-- Hero -->
      <section class="lp-hero">
        <div class="container">
          <h1 class="lp-hero-title">Softwareentwickler aus M&uuml;lheim an der Ruhr &mdash; Dennis Reichenberg</h1>
          <p class="lp-hero-text">
            Sie suchen einen erfahrenen Softwareentwickler im Ruhrgebiet? Dennis Reichenberg ist freiberuflicher Software Engineer aus M&uuml;lheim an der Ruhr und unterst&uuml;tzt Unternehmen, Startups und Agenturen dabei, ihre digitalen Produkte schneller und zuverl&auml;ssiger umzusetzen. Als lokaler Ansprechpartner kennt er den regionalen Markt und arbeitet eng mit Kunden aus dem Ruhrgebiet zusammen &mdash; pers&ouml;nlich vor Ort oder flexibel remote.
          </p>
          <div class="lp-hero-cta">
            <a href="#kontakt-muelheim" class="btn btn-primary">Kontakt aufnehmen</a>
          </div>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- Leistungen -->
      <section id="leistungen" class="lp-section">
        <div class="container">
          <h2 class="section-title">Leistungen als Freelance Developer aus dem Ruhrgebiet</h2>
          <p class="section-subtitle">Massgeschneiderte L&ouml;sungen f&uuml;r Ihre digitalen Herausforderungen</p>

          <div class="services-grid">
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 12 2 2 4-4"/></svg>
              </div>
              <h3>Webentwicklung M&uuml;lheim</h3>
              <p>Moderne, performante Webanwendungen mit React, Vue.js und Next.js</p>
            </div>

            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
              </div>
              <h3>Backend-Entwicklung</h3>
              <p>Skalierbare APIs und Serverl&ouml;sungen mit Node.js und Python</p>
            </div>

            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
              </div>
              <h3>Cloud &amp; Infrastruktur</h3>
              <p>Deployment auf AWS, Vercel und weiteren Cloud-Plattformen</p>
            </div>

            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              </div>
              <h3>IT-Beratung Ruhrgebiet</h3>
              <p>Technische Roadmaps und Stack-Empfehlungen f&uuml;r Startups und KMU</p>
            </div>

            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
              </div>
              <h3>Code-Review &amp; Architektur</h3>
              <p>Qualit&auml;tssicherung und Verbesserung bestehender Codebasen</p>
            </div>
          </div>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- Tech-Stack -->
      <section id="tech-stack" class="lp-section">
        <div class="container">
          <h2 class="section-title">Mein Tech-Stack als Software Engineer</h2>
          <p class="section-subtitle">Bew&auml;hrte und zukunftssichere Technologien</p>

          <div class="stack-grid">
            <div class="stack-card">
              <h3>Frontend</h3>
              <p>React, Vue.js, TypeScript, Next.js, Tailwind CSS &mdash; f&uuml;r schnelle, barrierefreie Benutzerinterfaces.</p>
            </div>

            <div class="stack-card">
              <h3>Backend &amp; APIs</h3>
              <p>Node.js, Python, REST und GraphQL &mdash; robuste Serverarchitekturen, die mit Ihrem Unternehmen wachsen.</p>
            </div>

            <div class="stack-card">
              <h3>Cloud &amp; DevOps</h3>
              <p>AWS, Docker, CI/CD-Pipelines, Vercel &mdash; f&uuml;r zuverl&auml;ssige Deployments und kurze Time-to-Market.</p>
            </div>
          </div>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- Warum lokal -->
      <section id="warum-lokal" class="lp-section">
        <div class="container">
          <h2 class="section-title">Warum ein lokaler Softwareentwickler aus M&uuml;lheim an der Ruhr?</h2>
          <p class="section-subtitle">Flexibilit&auml;t und Erreichbarkeit eines lokalen Partners</p>

          <div class="benefits-list">
            <div class="benefit-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span>Pers&ouml;nliche Meetings in M&uuml;lheim an der Ruhr, dem Ruhrgebiet und ganz NRW m&ouml;glich</span>
            </div>
            <div class="benefit-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span>Schnelle Reaktionszeiten und direkte, unkomplizierte Kommunikation</span>
            </div>
            <div class="benefit-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span>Vertrautheit mit dem lokalen Markt und den Bed&uuml;rfnissen von Ruhrgebiets-Unternehmen</span>
            </div>
            <div class="benefit-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span>Kein Overhead grosser Agenturen &mdash; Sie arbeiten direkt mit dem Entwickler</span>
            </div>
          </div>

          <p class="benefits-closing">
            Ob kurzfristige Projekthilfe, ein kompletter Produktaufbau oder langfristige technische Beratung: als Webentwickler aus M&uuml;lheim bin ich Ihr zuverl&auml;ssiger Partner f&uuml;r digitale Projekte jeder Gr&ouml;ssenordnung.
          </p>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- Projektablauf -->
      <section id="projektablauf" class="lp-section">
        <div class="container">
          <h2 class="section-title">Projektablauf &mdash; So arbeiten wir zusammen</h2>
          <p class="section-subtitle">Transparent und strukturiert vom Erstgespr&auml;ch bis zum Launch</p>

          <div class="steps-grid">
            <div class="step-card">
              <span class="step-number">1</span>
              <h3>Kostenfreies Erstgespr&auml;ch</h3>
              <p>Ich lerne Ihr Projekt und Ihre Anforderungen kennen. Gemeinsam kl&auml;ren wir Umfang, Timeline und Budget.</p>
            </div>

            <div class="step-card">
              <span class="step-number">2</span>
              <h3>Angebot und Planung</h3>
              <p>Sie erhalten ein transparentes, detailliertes Angebot mit klar definierten Meilensteinen ohne versteckte Kosten.</p>
            </div>

            <div class="step-card">
              <span class="step-number">3</span>
              <h3>Agile Umsetzung</h3>
              <p>Ich entwickle iterativ mit regelm&auml;ssigen Updates und binde Sie in alle wichtigen Entscheidungen ein.</p>
            </div>

            <div class="step-card">
              <span class="step-number">4</span>
              <h3>Abnahme und &Uuml;bergabe</h3>
              <p>Gemeinsame Qualit&auml;tspr&uuml;fung, saubere Dokumentation und reibungsloser Launch Ihres Projekts.</p>
            </div>
          </div>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- FAQ -->
      <section id="faq" class="lp-section">
        <div class="container">
          <h2 class="section-title">H&auml;ufige Fragen an Ihren Softwareentwickler aus dem Ruhrgebiet</h2>
          <p class="section-subtitle">Antworten auf die wichtigsten Fragen</p>

          <div class="faq-list">
            <details class="faq-item">
              <summary class="faq-question">Arbeiten Sie auch remote oder nur in M&uuml;lheim an der Ruhr?</summary>
              <p class="faq-answer">
                Ich arbeite prim&auml;r remote und bin deshalb &ouml;rtlich flexibel einsetzbar. F&uuml;r Kick-off-Meetings, Workshops oder regelm&auml;ssige Abstimmungen stehe ich im Raum M&uuml;lheim an der Ruhr, dem Ruhrgebiet und ganz NRW gerne pers&ouml;nlich zur Verf&uuml;gung.
              </p>
            </details>

            <details class="faq-item">
              <summary class="faq-question">F&uuml;r welche Unternehmensgr&ouml;ssen sind Sie der richtige Ansprechpartner?</summary>
              <p class="faq-answer">
                Ich unterst&uuml;tze sowohl Einzelunternehmer und Startups als auch mittelst&auml;ndische Unternehmen. Entscheidend ist ein klar definiertes Projektziel und die Bereitschaft zur agilen, ergebnisorientierten Zusammenarbeit.
              </p>
            </details>

            <details class="faq-item">
              <summary class="faq-question">Welche Projekte nehmen Sie an?</summary>
              <p class="faq-answer">
                Webentwicklung, mobile Web-Apps, Backend-APIs, Drittanbieter-Integrationen, technische Beratung, Code-Reviews sowie Architekturplanung. Auch tempor&auml;re Verst&auml;rkung f&uuml;r bestehende Entwicklungsteams ist m&ouml;glich &mdash; zum Beispiel als Freelancer auf Zeit oder f&uuml;r spezifische Teilprojekte.
              </p>
            </details>
          </div>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- CTA / Contact -->
      <section id="kontakt-muelheim" class="lp-section lp-cta-section">
        <div class="container">
          <h2 class="section-title">Bereit f&uuml;r Ihr n&auml;chstes Softwareprojekt im Ruhrgebiet?</h2>
          <p class="cta-text">
            Schildern Sie mir Ihre Anforderungen in einer kurzen Nachricht &mdash; ich melde mich innerhalb eines Werktages.
          </p>
          <div class="cta-actions">
            <a href="mailto:dennis@reichenberg.ruhr" class="btn btn-primary">Jetzt Kontakt aufnehmen</a>
            <a href="/#kontakt" class="btn btn-outline">Alle Kontaktoptionen</a>
          </div>
        </div>
      </section>
    </main>
    <Footer />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );

      document
        .querySelectorAll('.lp-section')
        .forEach((section) => observer.observe(section));
    </script>
  </body>
</html>

<style>
  /* ---- Landing Page Hero ---- */
  .lp-hero {
    padding: 8rem 0 5rem;
    background: radial-gradient(ellipse at 70% 40%, rgba(59, 130, 246, 0.08) 0%, transparent 60%);
  }

  .lp-hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.02em;
    color: #f8fafc;
    margin-bottom: 1.5rem;
  }

  .lp-hero-text {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 680px;
    margin-bottom: 2rem;
  }

  .lp-hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ---- Sections ---- */
  @media (prefers-reduced-motion: no-preference) {
    .lp-section {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.55s ease, transform 0.55s ease;
    }

    .lp-section.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ---- Services Grid ---- */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .service-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .service-icon {
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .service-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .service-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* ---- Tech Stack Grid ---- */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .stack-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
  }

  .stack-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--color-accent);
  }

  .stack-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* ---- Benefits List ---- */
  .benefits-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .benefit-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .benefit-item svg {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .benefits-closing {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    max-width: 680px;
  }

  /* ---- Steps Grid ---- */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .step-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
    position: relative;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .step-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }

  .step-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* ---- FAQ ---- */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 680px;
  }

  .faq-item {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .faq-question {
    padding: 1.25rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: #f1f5f9;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-size: 1.25rem;
    color: var(--color-accent);
    font-weight: 400;
    transition: transform 0.2s ease;
  }

  .faq-item[open] .faq-question::after {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 1.5rem 1.25rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* ---- CTA Section ---- */
  .lp-cta-section {
    text-align: center;
  }

  .lp-cta-section .section-title {
    display: block;
  }

  .lp-cta-section .section-title::after {
    margin-left: auto;
    margin-right: auto;
  }

  .cta-text {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    line-height: 1.8;
    max-width: 540px;
    margin: 0 auto 2rem;
  }

  .cta-actions {
