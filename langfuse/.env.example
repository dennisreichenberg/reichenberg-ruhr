# Langfuse self-hosted - environment variables
#
# Copy to .env in this directory before running docker compose:
#   cp langfuse/.env.example langfuse/.env
#
# Generate strong secrets for any *_SECRET / *_KEY / *_PASSWORD value:
#   openssl rand -base64 32         # NEXTAUTH_SECRET, SALT
#   openssl rand -hex 32            # ENCRYPTION_KEY (64 hex chars required)
#   openssl rand -base64 24         # passwords

# --- Langfuse application secrets -------------------------------------------
# 32-byte base64 used by NextAuth for session signing.
LANGFUSE_NEXTAUTH_SECRET=changeme-base64-32

# 32-byte base64 used to salt API keys before hashing.
LANGFUSE_SALT=changeme-base64-32

# 64 hex chars (256-bit). Used to encrypt sensitive table columns at rest.
LANGFUSE_ENCRYPTION_KEY=changeme-64-hex-chars

# Opt-out of anonymous self-host telemetry by setting false.
LANGFUSE_TELEMETRY_ENABLED=true
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false

# Tuning (leave blank for defaults):
LANGFUSE_INGESTION_QUEUE_DELAY_MS=
LANGFUSE_INGESTION_CLICKHOUSE_WRITE_INTERVAL_MS=

# --- Optional first-boot bootstrap -----------------------------------------
# If set, Langfuse seeds this org/project/user on first start. Useful for CI
# and for wiring SDK keys into clients (ollama-commit, local-rag) without a
# manual UI click.
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_ORG_NAME=
LANGFUSE_INIT_PROJECT_ID=
LANGFUSE_INIT_PROJECT_NAME=
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=

# --- Postgres (application metadata + auth) ---------------------------------
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=changeme-postgres
POSTGRES_DB=langfuse

# --- ClickHouse (traces, observations, scores) ------------------------------
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=changeme-clickhouse

# --- Redis (queues, rate limits) --------------------------------------------
REDIS_AUTH=changeme-redis

# --- MinIO (S3-compatible blob store for event + media uploads) -------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=changeme-minio
MINIO_BUCKET=langfuse

# --- Client SDK variables (consumed by ollama-commit / local-rag) ----------
# Not used by the compose stack itself; documented here for convenience so
# the same .env can source both server and client. After bootstrap, copy the
# project keys from the Langfuse UI (Project Settings -> API Keys).
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=pk-lf-changeme
LANGFUSE_SECRET_KEY=sk-lf-changeme
