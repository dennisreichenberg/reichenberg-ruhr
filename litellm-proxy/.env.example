# LiteLLM Proxy -- environment variables
#
# Copy to .env in this directory before running docker compose:
#   cp litellm-proxy/.env.example litellm-proxy/.env
#
# Generate a strong master key:
#   openssl rand -base64 32

# --- Required ---------------------------------------------------------------
# Master key: alle API-Clients muessen diesen Key als Bearer-Token senden.
# Format muss "sk-" prefix haben (LiteLLM-Konvention).
LITELLM_MASTER_KEY=sk-changeme

# --- Optional: Langfuse-Integration (REI-265) --------------------------------
# Aktivieren sobald der Langfuse-Stack laeuft. Danach in litellm_config.yaml
# die Callback-Zeilen auskommentieren.
LANGFUSE_HOST=http://host.docker.internal:3030
LANGFUSE_PUBLIC_KEY=pk-lf-changeme
LANGFUSE_SECRET_KEY=sk-lf-changeme

# --- Optional: Virtuelle Schluesselverwaltung (Postgres) --------------------
# Nur noetig wenn LiteLLM virtuelle API-Keys und Kostentracking nutzen soll.
# DATABASE_URL=postgresql://litellm:changeme@postgres:5432/litellm
